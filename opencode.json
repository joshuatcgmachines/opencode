{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "openai": {
      "options": {
        "websearch_cited": {
          "model": "gpt-5.4"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  },
  "plugin": [
    "@nick-vi/opencode-type-inject",
    "opencode-websearch-cited",
    "@franlol/opencode-md-table-formatter",
    "@mohak34/opencode-notifier"
  ]
}